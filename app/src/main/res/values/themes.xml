<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SuryaShakti" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/solar_yellow</item>
        <item name="colorPrimaryVariant">@color/solar_amber</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/energy_green</item>
        <item name="colorSecondaryVariant">@color/energy_green</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">#141414</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <style name="Theme.SuryaShakti.Splash" parent="Theme.SuryaShakti">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- Weather chips -->
    <style name="WeatherChipStyle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textSize">13sp</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Date picker custom dark theme -->
    <style name="DatePickerTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="colorPrimary">@color/solar_yellow</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:colorBackground">#1E1E1E</item>
    </style>

</resources>
