<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- Back button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="← Back"
        android:textColor="#FFD700"
        android:visibility="gone"
        style="@style/Widget.Material3.Button.TextButton"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀️ Solar Panel Location"
            android:textSize="22sp"
            android:textColor="#FFD700"
            android:fontFamily="sans-serif-bold"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Where are your solar panels installed?"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Tab Row -->
    <LinearLayout
        android:id="@+id/tabRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="0dp">

        <!-- Search Tab -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabSearch"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🔍  Search"
                android:textSize="14sp"
                android:textColor="#FFD700"
                android:backgroundTint="#1A1200"
                app:cornerRadius="10dp"/>

            <View
                android:id="@+id/viewTabIndicatorSearch"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="2dp"
                android:background="#FFD700"
                android:visibility="visible"/>
        </LinearLayout>

        <View android:layout_width="8dp" android:layout_height="1dp"/>

        <!-- Map Tab -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabMap"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🗺️  Map"
                android:textSize="14sp"
                android:textColor="#FFD700"
                android:backgroundTint="#141414"
                app:cornerRadius="10dp"/>

            <View
                android:id="@+id/viewTabIndicatorMap"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="2dp"
                android:background="#FFD700"
                android:visibility="invisible"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Thin divider under tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222222"
        android:layout_marginBottom="8dp"/>

    <!-- ══ SEARCH PANEL ══ -->
    <LinearLayout
        android:id="@+id/panelSearch"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:visibility="visible">

        <!-- Search input -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search city, area or landmark…"
                    app:hintTextColor="#888888"
                    app:boxStrokeColor="#FFD700"
                    app:boxStrokeWidth="2dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorColor="#FFD700"
                    app:trackColor="#333333"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hint / No results -->
        <TextView
            android:id="@+id/tvSearchHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type to search — e.g. Whitefield Bangalore, Anna Nagar Chennai"
            android:textSize="13sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingVertical="12dp"/>

        <TextView
            android:id="@+id/tvNoResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No locations found."
            android:textSize="14sp"
            android:textColor="#555555"
            android:gravity="center"
            android:visibility="gone"
            android:paddingVertical="20dp"/>

        <!-- Results -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvResults"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="8dp"
            android:clipToPadding="false"/>

        <!-- Confirm card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#0F1A00"
            app:cardCornerRadius="14dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Selected Location"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvConfirmName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#FFD700"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvConfirmCoords"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="USE THIS LOCATION"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:fontFamily="sans-serif-bold"
                    android:backgroundTint="#00E676"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ══ MAP PANEL ══ -->
    <LinearLayout
        android:id="@+id/panelMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Map fills most of screen -->
        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Bottom panel over map -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0A0A0A"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Location info row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvMapLocationName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap the map to place your panel"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvMapCoords"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- My location button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUseCurrentLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="📍 My Location"
                    android:textSize="12sp"
                    android:textColor="#FFD700"
                    android:backgroundTint="#1A1200"
                    app:cornerRadius="10dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp"/>
            </LinearLayout>

            <!-- Confirm map pin -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmMapLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="USE PINNED LOCATION"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#00E676"
                android:visibility="gone"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
