<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Pulse background ring -->
    <View
        android:id="@+id/viewStatusPulse"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_glow_circle"
        android:visibility="gone"/>

    <!-- Card content -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/bg_status_card">

        <!-- Spinner -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/statusSpinner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:indeterminate="true"
            app:indicatorColor="#FFD700"
            app:trackColor="#333333"
            app:trackThickness="4dp"
            android:visibility="gone"/>

        <!-- Emoji -->
        <TextView
            android:id="@+id/tvStatusEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀️"
            android:textSize="52sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvStatusTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvStatusSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:visibility="gone"/>
    </LinearLayout>

</FrameLayout>
