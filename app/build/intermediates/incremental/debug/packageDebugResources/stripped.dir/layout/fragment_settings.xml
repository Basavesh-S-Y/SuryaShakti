<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚙️  Settings"
                android:textSize="20sp"
                android:textColor="#FFD700"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- ══ SOLAR PANEL LOCATION CARD ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPanelLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#0F1A00"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️ Solar Panel Location"
                            android:textSize="14sp"
                            android:textColor="#FFD700"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Used for live irradiance data (W/m²)"
                            android:textSize="11sp"
                            android:textColor="#666666"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Current panel location display -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_stat_green"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCurrentPanelLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not set"
                            android:textSize="15sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvCurrentPanelCoords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="10sp"
                            android:textColor="#555555"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Reset button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetLocation"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="🔄  CHANGE PANEL LOCATION"
                    android:textSize="13sp"
                    android:textColor="#FFD700"
                    android:backgroundTint="#1A1200"
                    app:cornerRadius="10dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- ══ PROFILE CARD (name display — read only) ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1A1200"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <!-- Initials circle -->
                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="#FFD700"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:id="@+id/tvSettingsInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="U"
                        android:textSize="18sp"
                        android:textColor="#1A1A1A"
                        android:fontFamily="sans-serif-bold"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSettingsUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solar User"
                        android:textSize="17sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvSettingsUserEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ ENERGY RATES CARD ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Themes"
                    android:textSize="14sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp"/>

                <RadioGroup
                    android:id="@+id/rgTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbDarkTheme"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Dark"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:buttonTint="#FFD700"/>

                    <RadioButton
                        android:id="@+id/rbLightTheme"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Light"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:buttonTint="#FFD700"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardEnergyRates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Energy Rates"
                    android:textSize="14sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Grid Rate (₹/kWh)"
                        app:hintTextColor="#888888"
                        app:boxStrokeColor="#FFD700"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGridRate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Export Rate (₹/kWh)"
                        app:hintTextColor="#888888"
                        app:boxStrokeColor="#00E676"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etExportRate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ PANEL CAPACITY CARD ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPanelSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Solar Panel Capacity"
                    android:textSize="14sp"
                    android:textColor="#AAAAAA"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Installed Capacity (kW)"
                    app:hintTextColor="#888888"
                    app:boxStrokeColor="#FFD700"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPanelCapacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="#FFFFFF"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ NOTIFICATIONS ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔 Peak Sun Notifications"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alert when panel irradiance > 500 W/m²"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ ACCOUNT INFO ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAccountInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#0D1A2E"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Account"
                    android:textSize="14sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="8dp"/>

                <TextView android:id="@+id/tvAccountName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solar User"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"/>

                <TextView android:id="@+id/tvAccountEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="user@email.com"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>

                <TextView android:id="@+id/tvAccountType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google Account"
                    android:textSize="11sp"
                    android:textColor="#FFD700"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:text="💾  SAVE SETTINGS"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#FFD700"
            app:cornerRadius="14dp"/>

        <TextView
            android:id="@+id/tvSaveConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="✅ Settings saved!"
            android:textSize="14sp"
            android:textColor="#00E676"
            android:visibility="gone"
            android:paddingBottom="4dp"/>

        <!-- Sign Out -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:text="🚪  SIGN OUT"
            android:textSize="14sp"
            android:textColor="#FF5252"
            android:backgroundTint="#1A0000"
            app:cornerRadius="12dp"
            app:strokeColor="#FF5252"
            app:strokeWidth="1dp"/>

        <!-- App version -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ಸೂರ್ಯ ಶಕ್ತಿ  v4.0  •  suryashakti-bas.firebasestorage.app"
            android:textSize="10sp"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
