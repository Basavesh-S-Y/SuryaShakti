<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="22sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  30-Day Report"
                android:textSize="20sp"
                android:textColor="#FFD700"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Bar Chart Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Generation vs Consumption (kWh)"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="4dp"/>

                <com.suryashakti.solarmonitor.custom.EnergyBarChart
                    android:id="@+id/barChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Grade Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#1A1200"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Grade Circle -->
                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardBackgroundColor="#FFD700"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvGrade"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="A"
                        android:textSize="34sp"
                        android:textColor="#1A1A1A"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvGradeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solar Champion! 🌟"
                        android:textSize="18sp"
                        android:textColor="#FFD700"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Independence Score"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressAvgScore"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:indicatorColor="#FFD700"
                            app:trackColor="#333333"
                            app:trackCornerRadius="4dp"
                            android:progress="0"/>

                        <TextView
                            android:id="@+id/tvAvgScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="14sp"
                            android:textColor="#FFD700"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDaysLogged"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/30 days"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Financial Summary Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFinancials"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#0F1A00"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Financial Impact (30 Days)"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Grid Saved"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvTotalSaved"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="24sp"
                            android:textColor="#FFD700"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Export Earned"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvTotalEarned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="24sp"
                            android:textColor="#00E676"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Benefit"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvTotalBenefit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="24sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Energy Totals Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Energy Totals"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="☀️ Generated" android:textSize="10sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvTotalGenerated" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.0\nkWh"
                            android:textSize="16sp" android:textColor="#FFD700"
                            android:fontFamily="sans-serif-bold" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏠 Consumed" android:textSize="10sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvTotalConsumed" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.0\nkWh"
                            android:textSize="16sp" android:textColor="#FF5252"
                            android:fontFamily="sans-serif-bold" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔋 Exported" android:textSize="10sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvTotalExported" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.0\nkWh"
                            android:textSize="16sp" android:textColor="#00E676"
                            android:fontFamily="sans-serif-bold" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔌 Imported" android:textSize="10sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvTotalImported" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.0\nkWh"
                            android:textSize="16sp" android:textColor="#AAAAAA"
                            android:fontFamily="sans-serif-bold" android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Solar Coverage -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solar Coverage:"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressSolarCoverage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="10dp"
                        app:indicatorColor="#00E676"
                        app:trackColor="#333333"
                        app:trackCornerRadius="4dp"
                        android:progress="0"/>

                    <TextView
                        android:id="@+id/tvSolarCoverage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="14sp"
                        android:textColor="#00E676"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>

                <!-- CO2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌿 CO₂ Prevented:"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvCo2Saved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 kg CO₂"
                        android:textSize="14sp"
                        android:textColor="#00E676"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Monthly Bill Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#0A0014"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧾 Monthly Bill Comparison"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Without Solar"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvBillWithout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="22sp"
                            android:textColor="#FF5252"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="20sp"
                        android:textColor="#555555"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="With Solar"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvActualBill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="22sp"
                            android:textColor="#FFD700"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_green"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvBillSaving"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0 saved!"
                            android:textSize="15sp"
                            android:textColor="#00E676"
                            android:fontFamily="sans-serif-bold"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ════════ DAILY LOGS — expandable list ════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDailyLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📋 Daily Records"
                        android:textSize="14sp"
                        android:textColor="#AAAAAA"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap any row to expand"
                        android:textSize="11sp"
                        android:textColor="#555555"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDailyLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ════════ EXPORT CSV CARD ════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#0A0A14"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📤 Export Data"
                            android:textSize="14sp"
                            android:textColor="#AAAAAA"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvTotalRecords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All records — CSV format"
                            android:textSize="12sp"
                            android:textColor="#555555"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exports ALL records (not just 30 days) with full detail to Downloads folder as CSV. Open with Excel, Google Sheets, or any spreadsheet app."
                    android:textSize="12sp"
                    android:textColor="#444444"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="14dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportCsv"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="📤  EXPORT ALL AS CSV"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:fontFamily="sans-serif-bold"
                    android:backgroundTint="#00E676"
                    app:cornerRadius="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
