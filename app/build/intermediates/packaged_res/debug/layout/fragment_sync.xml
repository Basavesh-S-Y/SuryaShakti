<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☁️  Cloud Sync"
                    android:textSize="20sp"
                    android:textColor="#FFD700"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:id="@+id/ivSyncIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_nav_report"
                    android:contentDescription="@null"/>
            </LinearLayout>

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0D1A2E"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Initials circle -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="#FFD700"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:id="@+id/tvProfileInitials"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="U"
                            android:textSize="22sp"
                            android:textColor="#1A1A1A"
                            android:fontFamily="sans-serif-bold"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Name + email -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Solar User"
                            android:textSize="17sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="user@email.com"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tvAuthBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google Account"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_badge_rounded"/>
                    </LinearLayout>

                    <!-- Sign out -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Out"
                        android:textSize="12sp"
                        android:textColor="#FF5252"
                        style="@style/Widget.Material3.Button.TextButton"
                        app:rippleColor="#1AFF5252"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Not logged in card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardNotLoggedIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1A1200"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="36sp" android:gravity="center"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Not logged in"
                        android:textSize="16sp" android:textColor="#FFD700"
                        android:fontFamily="sans-serif-medium" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Go to Settings to sign in and enable cloud sync."
                        android:textSize="12sp" android:textColor="#888888"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sync Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSyncInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#141414"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📱 Local Records"
                                android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/tvLocalRecords"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0 records"
                                android:textSize="18sp" android:textColor="#FFD700"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="☁️ Sync Status"
                                android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/tvSyncStatus"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ready to sync"
                                android:textSize="14sp" android:textColor="#AAAAAA"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- What sync does -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔄  Uploads your logs to Firebase Firestore\n⬇️  Downloads logs from other devices\n🔒  Secure — only you can access your data"
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:lineSpacingMultiplier="1.5"
                        android:background="@drawable/bg_stat_green"
                        android:padding="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sync Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSync"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:text="☁️  SYNC NOW"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#FFD700"
                app:cornerRadius="14dp"/>

            <!-- Retry Button (only shown on error) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetrySync"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:text="🔄  Retry Sync"
                android:textSize="14sp"
                android:textColor="#FF5252"
                android:backgroundTint="#1A0000"
                app:cornerRadius="12dp"
                app:strokeColor="#FF5252"
                app:strokeWidth="1dp"
                android:visibility="gone"/>

            <!-- Last Sync Result Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLastSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0F1A00"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅ Last Sync Result"
                        android:textSize="13sp" android:textColor="#00E676"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <TextView android:id="@+id/tvLastSyncUploaded"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↑ 0 records uploaded"
                        android:textSize="13sp" android:textColor="#AAAAAA"/>

                    <TextView android:id="@+id/tvLastSyncDownloaded"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↓ 0 records downloaded"
                        android:textSize="13sp" android:textColor="#AAAAAA"/>

                    <TextView android:id="@+id/tvLastSyncTime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="11sp" android:textColor="#555555"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.suryashakti.solarmonitor.custom.StatusOverlayView
        android:id="@+id/statusOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</FrameLayout>
