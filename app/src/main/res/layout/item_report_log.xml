<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Summary Row (always visible, tap to expand) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical">

            <!-- Left: Date + Weather -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvReportDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01 Jan 2025"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvReportWeather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️ Sunny"
                    android:textSize="11sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Center: Gen / Consumed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvReportGenerated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️ 0.00 kWh"
                    android:textSize="12sp"
                    android:textColor="#FFD700"/>

                <TextView
                    android:id="@+id/tvReportConsumed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 0.00 kWh"
                    android:textSize="12sp"
                    android:textColor="#FF5252"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Right: Savings + Score + Expand arrow -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvReportSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textSize="14sp"
                    android:textColor="#00E676"
                    android:fontFamily="sans-serif-bold"/>

                <TextView
                    android:id="@+id/tvReportScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="12sp"
                    android:textColor="#FFD700"
                    android:fontFamily="sans-serif-bold"
                    android:gravity="end"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Expand arrow -->
            <ImageView
                android:id="@+id/ivExpandArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_expand_arrow"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/dividerExpand"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#252525"/>

        <!-- ── Expanded Detail Section ── -->
        <LinearLayout
            android:id="@+id/layoutExpanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="#141414"
            android:visibility="gone">

            <!-- Net Energy badge -->
            <TextView
                android:id="@+id/tvDetailNetEnergy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#00E676"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="12dp"/>

            <!-- Two-column detail grid -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:id="@+id/tvDetailSolarCoverage"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#AAAAAA"/>
                <TextView android:id="@+id/tvDetailEfficiency"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#AAAAAA"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:id="@+id/tvDetailExported"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#00E676"/>
                <TextView android:id="@+id/tvDetailImported"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#FF5252"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:id="@+id/tvDetailGridSaved"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#FFD700"/>
                <TextView android:id="@+id/tvDetailExportEarned"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#00E676"/>
            </LinearLayout>

            <TextView android:id="@+id/tvDetailTotalBenefit"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="6dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#252525" android:layout_marginVertical="6dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView android:id="@+id/tvDetailRate"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#555555"/>
                <TextView android:id="@+id/tvDetailExportRate"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#555555"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView android:id="@+id/tvDetailCapacity"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#555555"/>
                <TextView android:id="@+id/tvDetailCo2"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#4CAF50"/>
            </LinearLayout>

            <TextView android:id="@+id/tvDetailNotes"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#888888"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
